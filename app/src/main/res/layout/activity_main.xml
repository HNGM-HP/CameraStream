<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5faff">

    <!-- Streaming UI -->
    <com.hngm.camerastream.AutoFitTextureView
        android:id="@+id/surfacePreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Streaming overlay: tap to show status (initially invisible) -->
    <FrameLayout
        android:id="@+id/streamOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:clickable="true">

        <LinearLayout
            android:id="@+id/topControlBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="0dp"
            android:paddingEnd="8dp"
            android:paddingBottom="0dp">

            <ImageButton
                android:id="@+id/btnBattery"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/overlay_icon_bg"
                android:contentDescription="电量"
                android:padding="8dp"
                android:src="@drawable/ic_battery"
                app:tint="#ffffff" />

            <TextView
                android:id="@+id/overlayBatteryLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="--%"
                android:textColor="#ffffff"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:visibility="invisible">

                <TextView
                    android:id="@+id/overlayStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已连接"
                    android:textColor="#ffffff"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/overlayServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="192.168.1.100:8055"
                    android:textColor="#d1d5db"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/overlayFrameRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="30fps | H.264 | 1280x720"
                    android:textColor="#d1d5db"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnBeauty"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/overlay_icon_bg"
                android:contentDescription="一键美颜"
                android:padding="8dp"
                android:src="@drawable/ic_magic"
                app:tint="#ffffff" />

            <ImageButton
                android:id="@+id/btnMirror"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/overlay_icon_bg"
                android:contentDescription="镜像镜头"
                android:padding="8dp"
                android:src="@drawable/ic_mirror"
                app:tint="#ffffff" />

            <ImageButton
                android:id="@+id/btnSwitchCamera"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/overlay_icon_bg"
                android:contentDescription="切换摄像头"
                android:padding="8dp"
                android:src="@drawable/ic_flip_camera"
                app:tint="#ffffff" />

            <ImageButton
                android:id="@+id/btnTorch"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/overlay_icon_bg"
                android:contentDescription="@string/btn_torch"
                android:padding="8dp"
                android:src="@drawable/ic_flashlight"
                app:tint="#ffffff" />

            <ImageButton
                android:id="@+id/btnOverlaySettings"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/overlay_icon_bg"
                android:contentDescription="设置"
                android:padding="8dp"
                android:src="@drawable/ic_settings"
                app:tint="#ffffff" />

            <ImageButton
                android:id="@+id/btnScreenOff"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/overlay_icon_bg"
                android:contentDescription="熄屏"
                android:padding="8dp"
                android:src="@drawable/ic_screen_off"
                app:tint="#ffffff" />

            <ImageButton
                android:id="@+id/btnDisconnect"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/overlay_icon_bg"
                android:contentDescription="断开"
                android:padding="10dp"
                android:src="@drawable/ic_power"
                app:tint="#ffffff" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottomControlBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#66000000"
            android:clickable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="6dp"
            android:paddingEnd="8dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/controlShutter"
                style="@style/OverlayControlText"
                android:text="快门\nAUTO" />

            <TextView
                android:id="@+id/controlIso"
                style="@style/OverlayControlText"
                android:text="ISO\nAUTO" />

            <TextView
                android:id="@+id/controlExposure"
                style="@style/OverlayControlText"
                android:text="亮度\n0" />

            <TextView
                android:id="@+id/controlWhiteBalance"
                style="@style/OverlayControlText"
                android:text="色温\nAUTO" />

            <TextView
                android:id="@+id/controlFocus"
                style="@style/OverlayControlText"
                android:text="焦距\nAUTO" />

            <TextView
                android:id="@+id/controlZoom"
                style="@style/OverlayControlText"
                android:text="倍率\n1.0x" />

        </LinearLayout>

    </FrameLayout>

    <View
        android:id="@+id/focusLockIndicator"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/focus_lock_indicator"
        android:clickable="false"
        android:enabled="false"
        android:importantForAccessibility="no"
        android:visibility="gone" />

    <!-- Preview closed indicator -->
    <TextView
        android:id="@+id/previewClosedHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="预览已关闭（省电模式）\n点击屏幕打开"
        android:textColor="#94a3b8"
        android:textSize="18sp"
        android:visibility="gone" />

    <!-- Search UI -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/searchLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/circleContainer"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginTop="100dp"
            android:background="@drawable/circle_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_phone"
                    app:tint="#80c4ff" />

                <TextView
                    android:id="@+id/textIpAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="127.0.0.1"
                    android:textColor="#888888"
                    android:textSize="16sp" />
            </LinearLayout>
        </FrameLayout>

        <ImageView
            android:id="@+id/imgLaptop"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/ic_laptop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/circleContainer" />

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/searching"
            android:textColor="#888888"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgLaptop" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_refresh" />

            <ImageButton
                android:id="@+id/btnAdd"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add" />

            <ImageButton
                android:id="@+id/btnHelp"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_help" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/screenOffLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

</FrameLayout>
